        "title": "<span style=\"font-size: 46px;\"><span style=\"text-align: center;\"><span style=\"text-decoration: underline;\"><span style=\"color: rgb(255, 192, 0);\"><span><span><span><span><span style=\"font-weight: 400;\"><span style=\"font-weight: 700;\"><span style=\"font-weight: 400;\"><span style=\"font-style: italic;\"><span style=\"font-style: normal;\"><span><span><span><span><span style=\"font-size: 48px;\">Our platform users can't stop talking about us...</span></span></span></span></span></span></span></span></span></span></span></span></span></span></span></span></span></span>",
        "sectionAnimation": "fade-up",
