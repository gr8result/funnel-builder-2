        "paddingTop": 70,
        "paddingBottom": 70,
        "textAnimation": "fade-up",
        "enableParallax": false,
        "textLineHeight": 1.45,
        "backgroundColor": "#121c26",
        "baseLayoutWidth": 1500,
        "fullWidthBackground": true
      }
    },
