  "html": "<!DOCTYPE html>\n<html>\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <title>SMS</title>\n  </head>\n  <body style=\"margin:0;background:#ffffff;font-family:'Manrope','Avenir Next','Segoe UI',sans-serif;\">\n    <header style=\"background:#0b1220;color:#e2e8f0;border-bottom:1px solid rgba(148,163,184,0.2);\">\n        <div style=\"max-width:1120px;margin:0 auto;padding:56px 20px;padding-top:18px;padding-bottom:18px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;\">\n          <strong style=\"font-size:20px;\">Gr8 Result Digital Solutions</strong>\n          <nav style=\"display:flex;align-items:center;gap:14px;flex-wrap:wrap;\"><a href=\"#home\" style=\"color:#e2e8f0;text-decoration:none;font-weight:600;\">Home</a><span style='width:14px;display:inline-block;'></span><a href=\"#about\" style=\"color:#e2e8f0;text-decoration:none;font-weight:600;\">About</a><span style='width:14px;display:inline-block;'></span><a href=\"#services\" style=\"color:#e2e8f0;text-decoration:none;font-weight:600;\">Services</a><span style='width:14px;display:inline-block;'></span><a href=\"#contact\" style=\"color:#e2e8f0;text-decoration:none;font-weight:600;\">Contact</a></nav>\n          <a href=\"#contact\" style=\"background:#ffffff;color:#0f172a;padding:10px 16px;border-radius:999px;text-decoration:none;font-weight:700;\">Get Started</a>\n        </div>\n      </header>\n<section style=\"position:relative;overflow:hidden;padding:88px 20px;min-height:560px;background:linear-gradient(rgba(15,23,42,0.45), rgba(15,23,42,0.22)), url('https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&amp;fit=crop&amp;w=1600&amp;q=80') center/cover no-repeat;color:#ffffff;text-align:center;\">\n        \n        <div style=\"position:relative;z-index:1;max-width:680px;margin:0 auto;overflow:hidden;\">\n          <h1 style=\"margin:0 0 16px;font-size:52px;line-height:1.08;word-break:break-word;overflow-wrap:anywhere;\">Gr8 Result Digital Solutions helps your audience take the next step faster</h1>\n          <div style=\"font-size:20px;line-height:1.7;color:#dbeafe;word-break:break-word;overflow-wrap:anywhere;\"><p style=\"margin:0 0 16px;\">Use this homepage to explain your main offer clearly, build trust quickly, and move visitors toward get more enquiries.</p></div>\n          <a href=\"#\" style=\"display:inline-block;margin-top:18px;background:#ffffff;color:#1d4ed8;padding:12px 18px;border-radius:999px;text-decoration:none;font-weight:700;\">Get Started</a>\n        </div>\n      </section>\n<section style=\"background:#ffffff;color:#0f172a;\"><div style=\"max-width:1120px;margin:0 auto;padding:56px 20px;\"><h2 style=\"margin:0 0 18px;font-size:34px;\">What this site should communicate</h2><div style=\"display:grid;gap:12px;\"><div style=\"display:flex;gap:10px;align-items:flex-start;margin:0 0 10px;padding:14px;border-radius:14px;background:#eff6ff;border:1px solid #dbeafe;\"><span style=\"font-weight:800;\">✓</span><span>Offer: your main offer</span></div><div style=\"display:flex;gap:10px;align-items:flex-start;margin:0 0 10px;padding:14px;border-radius:14px;background:#eff6ff;border:1px solid #dbeafe;\"><span style=\"font-weight:800;\">✓</span><span>Audience: your audience</span></div><div style=\"display:flex;gap:10px;align-items:flex-start;margin:0 0 10px;padding:14px;border-radius:14px;background:#eff6ff;border:1px solid #dbeafe;\"><span style=\"font-weight:800;\">✓</span><span>Goal: get more enquiries</span></div></div></div></section>\n<section style=\"background:#ffffff;\"><div style=\"max-width:1120px;margin:0 auto;padding:56px 20px;\"><div style=\"display:flex;gap:14px;flex-wrap:wrap;\"></div></div></section>\n<section style=\"background:#ffffff;\"><div style=\"max-width:1120px;margin:0 auto;padding:56px 20px;\"><blockquote style=\"margin:0;padding:24px;border-radius:18px;background:#f8fafc;color:#0f172a;\"><p style=\"margin:0 0 12px;font-size:22px;line-height:1.6;\">“Gr8 Result Digital Solutions made our offer clearer and easier to act on.”</p><footer style=\"color:#475569;font-weight:700;\">Example Client — Customer</footer></blockquote></div></section>\n<section style=\"background:#ffffff;\"><div style=\"max-width:1120px;margin:0 auto;padding:56px 20px;;max-width:820px;\"><h2 style=\"margin:0 0 18px;font-size:34px;\"><p style=\"margin:0 0 16px;\">Questions before they buy</p></h2><details style=\"padding:14px 0;border-bottom:1px solid #e2e8f0;\"><summary style=\"cursor:pointer;font-weight:inherit;\"><p style=\"margin:0 0 16px;\">What is this?</p></summary><div style=\"margin:10px 0 0;color:#475569;\"><p style=\"margin:0 0 16px;\">This is the answer</p></div></details><details style=\"padding:14px 0;border-bottom:1px solid #e2e8f0;\"><summary style=\"cursor:pointer;font-weight:inherit;\"><p style=\"margin:0 0 16px;\">How does it work?</p></summary><div style=\"margin:10px 0 0;color:#475569;\"><p style=\"margin:0 0 16px;\">It works like this...</p></div></details></div></section>\n<section style=\"background:linear-gradient(180deg,#ffffff,#f8fafc);\"><div style=\"max-width:1120px;margin:0 auto;padding:56px 20px;\"><div style=\"max-width:760px;margin:0 auto;display:grid;grid-template-columns:1fr;gap:22px;align-items:stretch;\"><div style=\"background:#ffffff;border-radius:28px;padding:24px;box-shadow:0 18px 36px rgba(15,23,42,0.08);border:1px solid rgba(203,213,225,0.8);width:100%;box-sizing:border-box;\"><div style=\"margin:0 0 10px;font-size:34px;color:#0f172a;\"><p style=\"margin:0 0 16px;\">Start the conversation</p></div><div style=\"font-size:18px;color:#475569;\"><p style=\"margin:0 0 16px;\">Invite your audience to enquire now.</p></div><div style=\"display:grid;gap:12px;margin-top:18px;\"><div style=\"display:grid;gap:6px;\"><label style=\"color:#0f172a;font-size:16px;font-weight:700;\">Your Name</label><input placeholder=\"Jane Smith\" style=\"padding:12px 14px;border:1px solid #cbd5e1;background:#ffffff;color:#0f172a;border-radius:14px;\" /></div><div style=\"display:grid;gap:6px;\"><label style=\"color:#0f172a;font-size:16px;font-weight:700;\">Your Email</label><input placeholder=\"jane@example.com\" style=\"padding:12px 14px;border:1px solid #cbd5e1;background:#ffffff;color:#0f172a;border-radius:14px;\" /></div><div style=\"display:grid;gap:6px;\"><label style=\"color:#0f172a;font-size:16px;font-weight:700;\">Message</label><textarea placeholder=\"Tell us how we can help\" style=\"padding:12px 14px;border:1px solid #cbd5e1;background:#ffffff;color:#0f172a;border-radius:14px;min-height:120px;\"></textarea></div><div style=\"margin-top:16px;display:inline-flex;align-items:center;justify-content:center;min-height:48px;padding:12px 18px;background:#0f172a;color:#ffffff;border:none;border-radius:12px;font-weight:800;box-shadow:0 14px 28px rgba(15,23,42,0.18);\"><p style=\"margin:0 0 16px;\">Send Details</p></div></div></div></div></div></section>\n  </body>\n</html>",
