{
  "env": {
    "PINTEREST_USE_SANDBOX": "true"
  },
  "crons": [
    {
      "path": "/api/automation/engine/tick",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/email/autoresponders/process-queue",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/smsglobal/flush-queue",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/social/cron/process-schedule",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/social/cron/process-queue",
      "schedule": "5 4 * * *"
    },
    {
      "path": "/api/social/cron/refresh-tokens",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/calendar/send-reminders",
      "schedule": "0 1 * * *"
    }
  ]
}