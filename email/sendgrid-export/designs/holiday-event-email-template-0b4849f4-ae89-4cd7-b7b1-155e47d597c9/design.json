odule\" data-type=\"columns\" style=\"padding:30px 20px 30px 20px;\" bgcolor=\"#cef0fb\" data-distribution=\"1\"\u003e\n    \u003ctbody\u003e\n      \u003ctr role=\"module-content\"\u003e\n        \u003ctd height=\"100%\" valign=\"top\"\u003e\u003ctable width=\"540\" style=\"width:540px; border-spacing:0; border-collapse:collapse; margin:0px 10px 0px 10px;\" cellpadding=\"0\" cellspacing=\"0\" align=\"left\" border=\"0\" bgcolor=\"\" class=\"column column-0\"\u003e\n      \u003ctbody\u003e\n        \u003ctr\u003e\n          \u003ctd style=\"padding:0px;margin:0px;border-spacing:0;\"\u003e\u003ctable class=\"wrapper\" role=\"module\" data-type=\"image\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"table-layout: fixed;\" data-muid=\"3259b25b-315b-4ed6-a942-21660a7b71b6\"\u003e\n    \u003ctbody\u003e\n      \u003ctr\u003e\n        \u003ctd style=\"font-size:6px; line-height:10px; padding:0px 0px 0px 0px;\" valign=\"top\" align=\"left\"\u003e\n          \u003cimg class=\"max-width\" border=\"0\" style=\"display:block; color:#000000; text-decoration:none; font-family:Helvetica, arial, sans-serif; font-size:16px;\" width=\"179\" alt=\"\" data-proportionally-constrained=\"true\" data-responsive=\"false\" src=\"http://cdn.mcauto-images-production.sendgrid.net/954c252fedab403f/18b3c71a-820f-4df8-b2ff-ccb317497e9c/179x43.png\" height=\"43\"\u003e\n        \u003c/td\u003e\n      \u003c/tr\u003e\n    \u003c/tbody\u003e\n  \u003c/table\u003e\u003c/td\u003e\n        \u003c/tr\u003e\n      \u003c/tbody\u003e\n    \u003c/table\u003e\u003c/td\u003e\n      \u003c/tr\u003e\n    \u003c/tbody\u003e\n  \u003c/table\u003e\u003ctable border=\"0\" cellpadding=\"0\" cellspacing=\"0\" align=\"center\" width=\"100%\" role=\"module\" data-type=\"columns\" style=\"padding:0px 20px 0px 20px;\" bgcolor=\"#cef0fb\" data-distribution=\"1\"\u003e\n    \u003ctbody\u003e\n      \u003ctr role=\"module-content\"\u003e\n        \u003ctd height=\"100%\" valign=\"top\"\u003e\u003ctable width=\"560\" style=\"width:560px; border-spacing:0; border-collapse:collapse; margin:0px 0px 0px 0px;\" cellpadding=\"0\" cellspacing=\"0\" align=\"left\" border=\"0\" bgcolor=\"\" class=\"column column-0\"\u003e\n      \u003ctbody\u003e\n        \u003ctr\u003e\n          \u003ctd style=\"padding:0px;margin:0px;border-spacing:0;\"\u003e\u003ctable class=\"module\" role=\"module\" data-type=\"text\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"table-layout: fixed;\" data-muid=\"cc66f30c-3af2-4c4a-8800-f44d32b0a05c\" data-mc-module-version=\"2019-10-22\"\u003e\n    \u003ctbody\u003e\n      \u003ctr\u003e\n        \u003ctd style=\"padding:50px 30px 30px 40px; line-height:36px; text-align:inherit; background-color:#fafafa;\" height=\"100%\" valign=\"top\" bgcolor=\"#fafafa\" role=\"module-content\"\u003e\u003cdiv\u003e\u003cdiv style=\"font-family: inherit; text-align: left\"\u003e\u003cspan style=\"color: #002643; font-size: 30px\"\u003eJoin us for our annual holiday celebration on December 21st!\u003c/span\u003e\u003c/div\u003e\u003cdiv\u003e\u003c/div\u003e\u003c/div\u003e\u003c/td\u003e\n      \u003c/tr\u003e\n    \u003c/tbody\u003e\n  \u003c/table\u003e\u003ctable border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"module\" data-role=\"module-button\" data-type=\"button\" role=\"module\" style=\"table-layout:fixed;\" width=\"100%\" data-muid=\"2bf64e69-0e0a-482c-9ac1-8ed1b79ec575\"\u003e\n      \u003ctbody\u003e\n        \u003ctr\u003e\n          \u003ctd align=\"left\" bgcolor=\"#fafafa\" class=\"outer-td\" style=\"padding:0px 0px 30px 40px; background-color:#fafafa;\"\u003e\n            \u003ctable border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"wrapper-mobile\" style=\"text-align:center;\"\u003e\n              \u003ctbody\u003e\n                \u003ctr\u003e\n                \u003ctd align=\"center\" bgcolor=\"#fafafa\" class=\"inner-td\" style=\"border-radius:6px; font-size:16px; text-align:left; background-color:inherit;\"\u003e\n                  \u003ca href=\"\" style=\"background-color:#fafafa; border:2px solid #002643; border-color:#002643; border-radius:0px; border-width:2px; color:#002643; display:inline-block; font-size:14px; font-weight:normal; letter-spacing:0px; line-height:normal; padding:12px 30px 12px 30px; text-align:center; text-decoration:none; border-style:solid; font-family:inherit;\" target=\"_blank\"\u003eEvent Calendar\u003c/a\u003e\n                \u003c/td\u003e\n                \u003c/tr\u003e\n              \u003c/tbody\u003e\n            \u003c/table\u003e\n          \u003c/td\u003e\n        \u003c/tr\u003e\n      \u003c/tbody\u003e\n    \u003c/table\u003e\u003ctable class=\"wrapper\" role=\"module\" data-type=\"image\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"table-layout: fixed;\" data-muid=\"b33f7f31-c6fb-420a-bcf4-f0b757b98292\"\u003e\n    \u003ctbody\u003e\n      \u003ctr\u003e\n        \u003ctd style=\"font-size:6px; line-height:10px; padding:0px 0px 0px 0px;\" valign=\"top\" align=\"center\"\u003e\n          \u003cimg class=\"max-width\" border=\"0\" style=\"display:block; color:#000000; text-decoration:none; font-family:Helvetica, arial, sans-serif; font-size:16px; max-width:100% !important; width:100%; height:auto !important;\" width=\"NaN\" alt=\"\" data-proportionally-constrained=\"true\" data-responsive=\"true\" src=\"http://cdn.mcauto-images-production.sendgrid.net/954c252fedab403f/af39dd46-6c48-492b-8ba5-87a3a8d31c06/525x291.png\"\u003e\n        \u003c/td\u003e\n      \u003c/tr\u003e\n    \u003c/tbody\u003e\n  \u003c/table\u003e\u003ctable class=\"module\" role=\"module\" data-type=\"text\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"table-layout: fixed;\" data-muid=\"cc66f30c-3af2-4c4a-8800-f44d32b0a05c.1\" data-mc-module-version=\"2019-10-22\"\u003e\n    \u003ctbody\u003e\n      \u003ctr\u003e\n        \u003ctd style=\"padding:40px 30px 18px 40px; line-height:36px; text-align:inherit; background-color:#002643;\" height=\"100%\" valign=\"top\" bgcolor=\"#002643\" role=\"module-content\"\u003e\u003cdiv\u003e\u003cdiv style=\"font-family: inherit; text-align: inherit\"\u003e\u003cspan style=\"color: #ffffff; font-size: 30px\"\u003eFun For The Entire Family.\u003c/span\u003e\u003c/div\u003e\u003cdiv\u003e\u003c/div\u003e\u003c/div\u003e\u003c/td\u003e\n      \u003c/tr\u003e\n    \u003c/tbody\u003e\n  \u003c/table\u003e\u003ctable class=\"module\" role=\"module\" data-type=\"text\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"table-layout: fixed;\" data-muid=\"1846b950-cbdd-4d2d-a0e7-5b16830ad309\" data-mc-module-version=\"2019-10-22\"\u003e\n    \u003ctbody\u003e\n      \u003ctr\u003e\n        \u003ctd style=\"padding:18px 40px 30px 40px; line-height:22px; text-align:inherit; background-color:#002643;\" height=\"100%\" valign=\"top\" bgcolor=\"#002643\" role=\"module-content\"\u003e\u003cdiv\u003e\u003cdiv style=\"font-family: inherit; text-align: inherit\"\u003e\u003cspan style=\"color: #ffffff\"\u003eJoin us for a community holiday celebration at Mar Vista Park!\u003c/span\u003e\u003c/div\u003e\n\u003cdiv style=\"font-family: inherit; text-align: inherit\"\u003e\u003cbr\u003e\u003c/div\u003e\n\u003cdiv style=\"font-family: inherit; text-align: inherit\"\u003e\u003cspan style=\"color: #ffffff\"\u003e+ Festive games and art supplies (paint, markers, stickers, and more)\u003c/span\u003e\u003c/div\u003e\n\u003cdiv style=\"font-family: inherit; text-align: inherit\"\u003e\u003cspan style=\"color: #ffffff\"\u003e\u003cbr\u003e\n+ Food and beverages (Snacks, treats, and beer/wine for adults over 21)\u003c/span\u003e\u003c/div\u003e\n\u003cdiv style=\"font-family: inherit; text-align: inherit\"\u003e\u003cspan style=\"color: #ffffff\"\u003e\u003cbr\u003e\n\u003c/span\u003e\u003cspan style=\"color: #ffffff\"\u003e\u003cstrong\u003eEVERYONE IS WELCOME\u003c/strong\u003e\u003c/span\u003e\u003cspan style=\"color: #fffff