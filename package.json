    "build:fresh": "node scripts/run-next-clean.mjs build --clean",
    "start": "node scripts/run-next-clean.mjs start",
    "start:fresh": "node scripts/run-next-clean.mjs start --clean",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
