    "test:standard-inclusions-management": "node scripts/test-standard-inclusions-management-regression.mjs",
    "test:standard-inclusions-onlyoffice": "node scripts/test-standard-inclusions-onlyoffice-contract.mjs",
    "standard-inclusions:upload-master": "node scripts/upload-standard-inclusions-master.mjs",
    "test:project-estimate-template": "node scripts/test-project-estimate-approved-template.mjs",
    "test:takeoff-v2": "node modules/takeoff-v2/tests/rotation.test.mjs && node modules/takeoff-v2/tests/coordinateTransform.test.mjs && node modules/takeoff-v2/tests/planStore.test.mjs",
