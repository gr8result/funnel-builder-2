  "html": "<!DOCTYPE html>\n<html>\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <title>Contact Us</title>\n  </head>\n  <body style=\"margin:0;background:#ffffff;font-family:'Manrope','Avenir Next','Segoe UI',sans-serif;\">\n    <header style=\"background:#0b1220;color:#e2e8f0;border-bottom:1px solid rgba(148,163,184,0.2);\">\n        <div style=\"max-width:1120px;margin:0 auto;padding:56px 20px;padding-top:18px;padding-bottom:18px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;\">\n          <strong style=\"font-size:20px;\">Gr8 Result Digital Solutions</strong>\n          <nav style=\"display:flex;align-items:center;gap:14px;flex-wrap:wrap;\"><a href=\"#home\" style=\"color:#e2e8f0;text-decoration:none;font-weight:600;\">Home</a><span style='width:14px;display:inline-block;'></span><a href=\"#about-us\" style=\"color:#e2e8f0;text-decoration:none;font-weight:600;\">About Us</a><span style='width:14px;display:inline-block;'></span><a href=\"#contact\" style=\"color:#e2e8f0;text-decoration:none;font-weight:600;\">CONtact</a></nav>\n          <a href=\"#contact\" style=\"background:#0ea5e9;color:#ffffff;padding:10px 16px;border-radius:999px;text-decoration:none;font-weight:700;\">Contact</a>\n        </div>\n      </header>\n<section style=\"background:#ffffff;color:#e6eef5;\">\n        <div style=\"max-width:1120px;margin:0 auto;padding:56px 20px;\"><div style=\"color: rgb(0, 176, 80);; text-align: center; font-size: 84px;\"><span><span style=\"font-weight: bold;\">Contact Us!</span></span></div></div>\n      </section>\n<section style=\"background:transparent;color:#0f172a;\"><div style=\"max-width:1120px;margin:0 auto;padding:56px 20px;\"><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:16px;\"><div style=\"padding:18px;border-radius:18px;background:#f8fafc;border:1px solid #dbeafe;\"><img src=\"https://bvtxfphktypdqmlnveqf.supabase.co