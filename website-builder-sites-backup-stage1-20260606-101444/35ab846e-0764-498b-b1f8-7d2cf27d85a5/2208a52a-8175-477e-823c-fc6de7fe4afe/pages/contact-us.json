;padding:24px;box-shadow:0 18px 36px rgba(15,23,42,0.08);border:1px solid rgba(203,213,225,0.8);width:100%;box-sizing:border-box;\"><div style=\"margin:0 0 10px;font-size:34px;color:#0f172a;\"><span style=\"line-height: 1.35;\"><span style=\"font-size: 48px;\"><span style=\"font-size: 48px; color: rgb(0, 112, 192);\">Ready To Grow Your Business?<span><br></span></span></span><span style=\"font-size: 36px;\">Let's Start The Conversation</span></span></div><div style=\"font-size:18px;color:#475569;\"><span style=\"color: rgb(0, 176, 80);\"><div style=\"text-align: center;\"><span style=\"font-size: 24px; font-family: inherit;\"><span style=\"font-size: 24px; line-height: 1.3; font-weight: bold;\">Tell us a little about your business and what you'd like to achieve. Our team will be in touch to discuss how we can help you achieve Gr8 Results.</span></span></div></span></div><div style=\"display:grid;gap:12px;margin-top:18px;\"><div style=\"display:grid;gap:6px;\"><label style=\"color:#0f172a;font-size:16px;font-weight:700;\">&lt;span style=&quot;font-size: 18px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Your Full Name&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;</label><input placeholder=\"Jane Smith\" style=\"padding:12px 14px;border:1px solid #0ea5e9;background:#ffffff;color:#747576;border-radius:14px;\" /></div><div style=\"display:grid;gap:6px;\"><label style=\"color:#0f172a;font-size:16px;font-weight:700;\">Your Email Address</label><input placeholder=\"jane@example.com\" style=\"padding:12px 14px;border:1px solid #0ea5e9;background:#ffffff;color:#747576;border-radius:14px;\" /></div><div style=\"display:grid;gap:6px;\"><label style=\"color:#0f172a;font-size:16px;font-weight:700;\">Your Best Contact Number</label><input placeholder=\"Your phone number\" style=\"padding:12px 14px;border:1px solid #0ea5e9;background:#ffffff;color:#747576;border-radius:14px;\" /></div><div style=\"display:grid;gap:6px;\"><label style=\"color:#0f172a;font-size:16px;font-weight:700;\">Business Name</label><input placeholder=\"Your Business Name\" style=\"padding:12px 14px;border:1px solid #0ea5e9;background:#ffffff;color:#747576;border-radius:14px;\" /></div><div style=\"display:grid;gap:6px;\"><label style=\"color:#0f172a;font-size:16px;font-weight:700;\">Your Message</label><textarea placeholder=\"Tell us about your business, your goals, or any challenges you&#39;re facing. We&#39;d love to learn more and see how we can help.\" style=\"padding:12px 14px;border:1px solid #0ea5e9;background:#ffffff;color:#747576;border-radius:14px;min-height:120px;\"></textarea></div><div style=\"margin-top:16px;display:inline-flex;align-items:center;justify-content:center;min-height:48px;padding:12px 18px;background:#0f172a;color:#84cc16;border:none;border-radius:12px;font-weight:800;box-shadow:0 14px 28px rgba(15,23,42,0.18);\"><span style=\"font-size: 24px;\">Let's Talk</span></div></div></div></div></div></section>\n<section style=\"background:#ffffff;\"><div style=\"max-width:1120px;margin:0 auto;padding:56px 20px;;text-align:center;\"><a href=\"https://gr8result.digital/login.\" style=\"display:inline-block;background:#0f172a;color:#ffffff;text-decoration:none;border-radius:999px;padding:12px 18px;font-weight:700;\">&lt;span style=&quot;font-size: 24px;&quot;&gt;&lt;span style=&quot;font-weight: bold;&quot;&gt;&lt;span style=&quot;font-size: 24px;&quot;&gt;Clich Here To Start Your 14 Day Free Trial&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;</a></div></section>\n  </body>\n</html>",
